{
  "name": "node-red-contrib-rpc-toolkit",
  "version": "2.3.0",
  "description": "JSON-RPC 2.0 client and server nodes for Node-RED with Safe Mode support",
  "main": "index.js",
  "scripts": {
    "test": "node --test --test-concurrency=1 test/rpc-client_spec.js test/rpc-response_spec.js test/rpc-server_spec.js",
    "audit:runtime": "npm audit --omit=dev",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "node-red",
    "json-rpc",
    "rpc",
    "client",
    "server",
    "iot",
    "automation",
    "microservices",
    "http",
    "safe-mode",
    "edge"
  ],
  "node-red": {
    "version": ">=3.0.0",
    "nodes": {
      "rpc-server": "nodes/rpc-server.js",
      "rpc-client": "nodes/rpc-client.js",
      "rpc-method": "nodes/rpc-method.js",
      "rpc-request": "nodes/rpc-request.js",
      "rpc-response": "nodes/rpc-response.js"
    }
  },
  "author": {
    "name": "Nicola Carpanese",
    "url": "https://github.com/n-car"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n-car/node-red-contrib-rpc-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/n-car/node-red-contrib-rpc-toolkit/issues"
  },
  "homepage": "https://github.com/n-car/node-red-contrib-rpc-toolkit#readme",
  "dependencies": {
    "express": "^5.2.1",
    "rpc-express-toolkit": "^4.3.5"
  },
  "devDependencies": {
    "node-red": "^5.0.0",
    "node-red-node-test-helper": "^0.3.6"
  },
  "files": [
    "index.js",
    "nodes/",
    "examples/",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
